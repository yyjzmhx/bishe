<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.personalmusicsystem.mapper.RecommendRecordMapper">
    
    <resultMap id="BaseResultMap" type="com.example.personalmusicsystem.entity.RecommendRecord">
        <id column="id" property="id"/>
        <result column="upload_id" property="uploadId"/>
        <result column="music_id" property="musicId"/>
        <result column="similarity" property="similarity"/>
        <result column="`rank`" property="rank"/>
        <result column="create_time" property="createTime"/>
        <association property="music" column="music_id" 
                     select="com.example.personalmusicsystem.mapper.MusicMapper.selectById"/>
    </resultMap>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO recommend_record (upload_id, music_id, similarity, `rank`)
        VALUES (#{uploadId}, #{musicId}, #{similarity}, #{rank})
    </insert>
    
    <insert id="insertBatch">
        INSERT INTO recommend_record (upload_id, music_id, similarity, `rank`)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.uploadId}, #{item.musicId}, #{item.similarity}, #{item.rank})
        </foreach>
    </insert>
    
    <select id="selectByUploadId" resultMap="BaseResultMap">
        SELECT * FROM recommend_record
        WHERE upload_id = #{uploadId}
        ORDER BY similarity DESC, `rank` ASC
    </select>
    
    <delete id="deleteByUploadId">
        DELETE FROM recommend_record WHERE upload_id = #{uploadId}
    </delete>
    
    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM recommend_record
    </select>

    <select id="selectAverageSimilarity" resultType="double">
        SELECT AVG(similarity) FROM recommend_record
    </select>
    
</mapper>

